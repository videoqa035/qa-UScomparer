# ─────────────────────────────────────────────────────────
# Atlassian credentials
# Copy this file to .env and fill in your values.
# ⚠  NEVER commit the real .env file – it is in .gitignore
# ─────────────────────────────────────────────────────────

# ── Jira Cloud ────────────────────────────────────────────
# Create a token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_TOKEN=your_api_token_here

# Your Atlassian account email (NOT NECESSARY - required for Jira Cloud only)
# ATLASSIAN_EMAIL=your@email.com

# Your Jira Cloud base URL  (e.g. https://your-org.atlassian.net)
JIRA_BASE_URL=https://jira.tid.es/

# ── Jira Data Center / Server ─────────────────────────────
# Use a Personal Access Token (PAT) and leave ATLASSIAN_EMAIL blank.
# ATLASSIAN_TOKEN=your_pat_here
# JIRA_BASE_URL=https://jira.yourcompany.com

# ── MCP server URL (optional – default is the Atlassian Remote MCP) ──
# ATLASSIAN_BASE_URL=https://mcp.atlassian.com
